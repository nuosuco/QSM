// 阶段2编译器 - 真正的QEntL编译器
// 能在QVM上运行，编译QEntL源码为字节码
// 功能：解析QEntL语法，生成QVM字节码

import "QCL模块/qcl_lexer.qentl" 作为 词法分析
import "QCL模块/qcl_parser.qentl" 作为 语法分析

// 编译器配置
def main():
    // 读取输入QEntL文件
    var input_file = "input.qentl"
    var output_file = "output.qbc"
    
    // 词法分析
    var tokens = 词法分析.分析(input_file)
    
    // 语法分析
    var ast = 语法分析.解析(tokens)
    
    // 生成字节码
    var bytecode = 生成字节码(ast)
    
    // 输出字节码
    写入字节码(output_file, bytecode)
    
    返回 0
