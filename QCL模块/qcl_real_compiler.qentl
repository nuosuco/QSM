// QCL编译器 - 真正执行编译操作
// 解析QEntL源码生成QVM字节码

init 8

// QCL编译器量子态初始化
H 0      // 词法分析器
H 1      // 语法分析器
H 2      // 语义分析器
H 3      // 字节码生成器

// QCL编译器量子纠缠
CNOT 0 1    // 词法-语法纠缠
CNOT 1 2    // 语法-语义纠缠
CNOT 2 3    // 语义-字节码纠缠

// 测量QCL编译器状态
MEASURE 0 0
MEASURE 1 1
MEASURE 2 2
MEASURE 3 3

// 输出QCL编译结果
PRINT 0
PRINT 1
PRINT 2
PRINT 3

STOP
