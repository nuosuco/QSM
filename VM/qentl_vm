#!/bin/bash
# QEntL量子虚拟机启动脚本
# 版本: v0.2.0

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo "🌟 QEntL量子虚拟机 v0.2.0"
echo "================================"
echo ""

# 检查Python
if ! command -v python3 &> /dev/null; then
    echo "❌ 需要Python 3"
    exit 1
fi

# 启动虚拟机
cd "$SCRIPT_DIR"
python3 src/main.py "$@"
