// ============================================================================
// test_phase2_full.qentl
// 阶段2编译器综合测试 — 验证所有编译能力
// ============================================================================

// ===== 1. 多行函数定义 + 函数体量子指令 =====
// C编译器限制：只输出函数名字符串，丢失函数体中的量子指令
// 阶段2增强：将函数体编译为真正的量子字节码
def prepare_bell: {
    init 2
    H 0
    CNOT 0 1
    STOP
}

// ===== 2. 单行简写函数定义 =====
def x_flip: X 0
def z_flip: Z 0

// ===== 3. 测量函数 =====
def measure_qubit: {
    MEASURE 0 0
    PRINT 0
}

// ===== 4. 复杂函数体（多指令） =====
def circuit: {
    init 3
    H 0
    CNOT 0 1
    CNOT 1 2
    MEASURE 0 0
    MEASURE 1 1
    MEASURE 2 2
    PRINT 0
    PRINT 1
    PRINT 2
    STOP
}

// ===== 5. 直接量子指令（不在函数中） =====
init 4
H 0
X 1
Z 2
CNOT 0 1
MEASURE 0 0
PRINT 0
STOP
