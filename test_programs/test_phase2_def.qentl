// ============================================================================
// test_phase2_def.qentl
// 阶段2编译器测试程序 — 测试 def 函数定义 + 量子指令编译
// ============================================================================

// 1. 定义贝尔态制备函数
def prep_bell: {
    init 2
    H 0
    CNOT 0 1
}

// 2. 定义单比特翻转函数（简写模式）
def flip: X 0

// 3. 定义测量函数
def measure_all: {
    MEASURE 0 0
    MEASURE 1 1
    PRINT 0
    PRINT 1
}

// 4. 调用函数
prep_bell()
flip()
measure_all()

// 5. 直接量子指令（混合格式）
H 0
CNOT 0 1
STOP
