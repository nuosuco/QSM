// QCL引导器.qentl — QCL (Quantum Compiler Language) 编译器核心
// QEntL全栈实现，由 qcl_bootstrap.c 编译为 QCL引导器.qbc
// ============================================================================
//
// 架构说明：
//   阶段1: qcl_bootstrap.c (C语言解释器) → 编译量子电路 .qentl → .qbc → QVM执行
//   阶段2: QCL引导器.qentl (本文件)   → 完整QCL编译器(QEntL源码)
//   阶段3: QCL编译器在QEntL环境中编译所有QEntL源码
//
// 本文件实现三个核心函数：
//   1. 新建编译器()    — 初始化编译器环境（opcode表/词法器/解析器/字节码缓冲区）
//   2. 扫描QEntL目录() — 递归扫描目录下的 .qentl 源文件
//   3. 编译器.编译()   — 将QEntL源码翻译为 .qbc 字节码（量子+经典双逻辑）
// ============================================================================

// ============================================================================
// 量子电路执行体（qcl_bootstrap可编译的部分）
// 用于验证编译器引导器的量子执行环境正确
// ============================================================================
init 8

// 初始化编译器状态寄存器：q0-q3 表示编译器核心状态
H 0          // 编译器启用标志 — 叠加态表示"已初始化"
H 1          // 扫描器启用标志
X 0          // 设置编译器状态为"就绪"

// q4-q7: 编译结果计数寄存器（用纠缠表示编译成功）
CNOT 0 4     // 编译器就绪 → 编译结果通道0
CNOT 1 5     // 扫描器就绪 → 编译结果通道1
CNOT 0 6     // 编译器就绪 → 编译结果通道2
CNOT 1 7     // 扫描器就绪 → 编译结果通道3

// 测量所有量子比特到经典寄存器
MEASURE 0 0
MEASURE 1 1
MEASURE 2 2
MEASURE 3 3
MEASURE 4 4
MEASURE 5 5
MEASURE 6 6
MEASURE 7 7

// 输出编译状态
PRINT 0      // 编译器状态
PRINT 1      // 扫描器状态
PRINT 2      // 解析器状态
PRINT 3      // 字节码生成器状态
PRINT 4      // 编译结果通道0
PRINT 5      // 编译结果通道1
PRINT 6      // 编译结果通道2
PRINT 7      // 编译结果通道7

