// QCL Class Syntax Comprehensive Test
// 测试 class 语法的各个方面：声明、成员函数、构造函数、继承、方法调用、静态方法

// 基础类：Point
class Point {
    var x: int
    var y: int
    
    constructor(x: int, y: int) {
        this.x = x
        this.y = y
        return
    }
    
    def get_x() -> int {
        return this.x
    }
    
    def get_y() -> int {
        return this.y
    }
    
    def set_x(x: int) {
        this.x = x
        return
    }
    
    def set_y(y: int) {
        this.y = y
        return
    }
    
    def distance(p: Point) -> int {
        var dx = this.x - p.get_x()
        var dy = this.y - p.get_y()
        return dx + dy
    }
}

// 继承类：ColoredPoint
class ColoredPoint extends Point {
    var color: string
    
    constructor(x: int, y: int, color: string) {
        super(x, y)
        this.color = color
        return
    }
    
    def get_color() -> string {
        return this.color
    }
    
    def set_color(color: string) {
        this.color = color
        return
    }
    
    def to_string() -> string {
        return this.color
    }
}

// 静态方法类：MathUtils
class MathUtils {
    static def add(a: int, b: int) -> int {
        return a + b
    }
    
    static def multiply(a: int, b: int) -> int {
        return a * b
    }
    
    static var counter: int = 0
}

// 构造函数测试类
class Counter {
    var value: int
    
    constructor() {
        this.value = 0
        return
    }
    
    def increment() {
        this.value = this.value + 1
        return
    }
    
    def get_value() -> int {
        return this.value
    }
}

// 方法调用测试
def main() {
    // 测试 Point 类
    var p1 = Point(10, 20)
    var x = p1.get_x()
    var y = p1.get_y()
    p1.set_x(30)
    
    // 测试继承
    var cp = ColoredPoint(100, 200, "red")
    var cx = cp.get_x()
    var color = cp.get_color()
    cp.set_color("blue")
    
    // 测试静态方法
    var sum = MathUtils.add(5, 10)
    var prod = MathUtils.multiply(3, 4)
    
    // 测试构造函数
    var c = Counter()
    c.increment()
    c.increment()
    var val = c.get_value()
    
    return
}
