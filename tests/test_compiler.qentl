# QEntL Full-Stack Integration Test
# Tests: compiler, QVM, QDFS, QNS, Four Models

# Initialize 4 qubits
init 4

# Create superposition on qubit 0
H 0

# Create superposition on qubit 1
H 1

# Entangle qubits 0 and 1 (Bell state)
CNOT 0 1

# Apply Hadamard to qubit 2
H 2

# Entangle qubits 2 and 3
CNOT 2 3

# Measure qubits
MEASURE 0 0
MEASURE 1 1
MEASURE 2 2
MEASURE 3 3

# Print quantum state
PRINT 0
PRINT 1

# Variable operations (commented out - LET opcode not yet implemented in compiler)
# let a = 1.5
# let b = 2.5

# Stop
STOP
