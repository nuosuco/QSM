// QVM完整执行体 - 混合文件（高级语法 + 量子指令）
// 由qcl_phase2编译，含函数体 + 量子指令

// 初始化
def vm_init():
    init 8
    return 0

// 创建贝尔态
def vm_create_bell():
    H 0
    H 1
    CNOT 0 1
    H 2
    H 3
    CNOT 2 3
    return 0

// 测量
def vm_measure():
    MEASURE 0 0
    MEASURE 1 1
    MEASURE 2 2
    MEASURE 3 3
    PRINT 0
    PRINT 1
    STOP
    return 0

// 主入口
def main():
    vm_init()
    vm_create_bell()
    vm_measure()
    return 0
