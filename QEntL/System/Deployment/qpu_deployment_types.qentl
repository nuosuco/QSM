// QPU部署类型定义
// 部署模式枚举与QPU适配器类型规范

quantum_enum DeploymentMode = {
    DEVELOPMENT = 0;
    PRODUCTION = 1;
    SPECIALIZED = 2;
};

quantum_enum QpuBackend = {
    QVM = 0;
    CLOUD = 1;
    HARDWARE = 2;
};

quantum_class QpuAdapter {
    var backend = "qvm";
    var connected = false;
}

export DeploymentMode;
export QpuBackend;
export QpuAdapter;
