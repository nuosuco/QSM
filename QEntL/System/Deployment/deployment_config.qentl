import "QEntL/System/Deployment/qpu_deployment_types.qentl"
import "QEntL/System/Deployment/qpu_runtime_detector.qentl"
import "QEntL/System/Deployment/deployment_router.qentl"

def get_deployment_config():
    config = {}
    config.mode = select_deployment_mode("auto")
    config.qpu_enabled = qpu_runtime_detector.check_qpu()
    config.qvm_fallback = true
    config.verbose = false
    
    return config

