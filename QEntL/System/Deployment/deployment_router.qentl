// 部署路由器 - 选择部署模式
import "QEntL/System/Deployment/qpu_deployment_types.qentl"
import "QEntL/System/Deployment/qpu_runtime_detector.qentl"

def select_deployment_mode(target_platform):
    // 自动检测部署目标
    qpu_available = qpu_runtime_detector.check_qpu()
    
    if qpu_available:
        return deployment_types.QPU_MODE
    else:
        return deployment_types.QVM_MODE
    
    return deployment_types.FALLBACK_MODE
