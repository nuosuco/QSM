    }
    
    // ============================================================
    // 测试报告
    // ============================================================
    函数 输出测试报告(套件: 测试套件) {
        日志("")
        日志("=" * 60)
        日志("测试报告")
        日志("=" * 60)
        日志(`总测试数: ${套件.总测试数}`)
        日志(`通过数: ${套件.通过数}`)
        日志(`失败数: ${套件.失败数}`)
        日志(`总耗时: ${套件.总耗时}ms`)
        日志("")
        
        如果 (套件.失败数 === 0) {
            日志("✓ 所有测试通过!")
        } 否则 {
            日志("✗ 部分测试失败:")
            对于 结果 在 套件.结果 {
                如果 (!结果.通过) {
                    日志(`  ✗ ${结果.名称}: ${结果.错误信息}`)
                }
            }
        }
        
        日志("=" * 60)
    }
}

