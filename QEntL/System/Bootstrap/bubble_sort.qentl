# 冒泡排序算法 — QEntL自举验证
# 输入: [5, 3, 8, 1, 2] → 输出: [1, 2, 3, 5, 8]

主函数: 函数() {
    让 arr = [5, 3, 8, 1, 2]
    让 n = 5
    让 i = 0
    
    当(i < n - 1) {
        让 j = 0
        当(j < n - i - 1) {
            如果(arr[j] > arr[j + 1]) {
                让 tmp = arr[j]
                arr[j] = arr[j + 1]
                arr[j + 1] = tmp
            }
            j = j + 1
        }
        i = i + 1
    }
    
    打印(arr[0])
    打印(arr[1])
    打印(arr[2])
    打印(arr[3])
    打印(arr[4])
}
