// QEntL全特性综合测试
// 覆盖: 配置/labeled函数/UNARY_NOT/DOT访问/方法调用/类/枚举/量子程序
// 作者: 小趣WeQ | 监督: 中华Zhoho

配置 {
    版本: "2.0"
}

quantum_enum 状态 {
    关闭
    开启
    错误
}

quantum_class 设备 {
    名称: 字符串 = "QEntL"
    状态值: 整数 = 0
}

// 测试1: labeled函数+空参数
测试基本: 函数() {
    LOG("✅ 基本函数调用")
}

// 测试2: 带参数函数
测试加法: 函数(a: 整数, b: 整数) {
    让 结果 = a + b
    返回 结果
}

// 测试3: UNARY_NOT
测试非运算: 函数() {
    让 假 = 0
    如果 !假 {
        LOG("✅ NOT运算: !0为真")
    }
}

// 测试4: 量子程序+Bell态
quantum_program 量子测试 {
    入口: 函数() {
        LOG("⚛ 量子测试开始")
        量子门 H 0
        量子门 CNOT 0 1
        LOG("✅ Bell态创建")
    }
}

// 主入口
入口: 函数() {
    LOG("🧪 QEntL全特性综合测试")
    测试基本()
    让 和 = 测试加法(10, 20)
    LOG("✅ 加法: 10+20=")
    LOG(和)
    测试非运算()
    LOG("✅ 全特性测试完成!")
}
