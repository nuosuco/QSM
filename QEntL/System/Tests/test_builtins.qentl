# QEntL 内建函数综合测试
测试内建: 函数() {
    # 长度
    让 arr = [10, 20, 30]
    LOG(长度(arr))
    
    # 推入
    推入(arr, 40)
    LOG(长度(arr))
    
    # 弹出
    让 last = 弹出(arr)
    LOG(last)
    
    # 最大值/最小值
    LOG(最大值(3, 7))
    LOG(最小值(3, 7))
    
    # 绝对值
    让 x = -42
    LOG(绝对值(x))
    
    # 类型
    LOG(类型(arr))
    LOG(类型(42))
    
    # 字符串操作
    让 s = "hello"
    LOG(长度(s))
    LOG(s[0])
    LOG(s + " world")
}
