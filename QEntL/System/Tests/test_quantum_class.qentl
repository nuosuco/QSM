// QEntL量子类测试 - 编译器现已支持quantum_class!
// 测试quantum_class + quantum_enum + quantum_program组合

配置 {
    测试模式: true,
    版本: "2.0.0"
}

// 量子状态枚举(已支持)
quantum_enum 量子状态 {
    叠加,
    纠缠,
    坍缩,
    退相干
}

// 量子门类型枚举(已支持)
quantum_enum 量子门类型 {
    Hadamard,
    CNOT,
    PauliX,
    PauliZ,
    测量
}

// 量子处理器类(新支持!)
quantum_class 量子处理器 {
    量子比特数: 整数 = 2,
    纠缠对数: 整数 = 0,
    函数 初始化() {
        LOG("⚛ 量子处理器初始化")
    }
    函数 执行Hadamard() {
        LOG("执行Hadamard门")
    }
    函数 测量全部() {
        LOG("测量所有量子比特")
    }
}

// 量子服务类(新支持!)
quantum_class 量子服务 {
    名称: 字符串,
    状态: 量子状态 = 量子状态.叠加,
    处理器: 量子处理器,
    函数 启动() {
        LOG("🚀 量子服务启动")
    }
    函数 停止() {
        LOG("🛑 量子服务停止")
    }
}

// 量子程序: 完整测试
quantum_program 类枚举量子测试 {
    setup: 函数() {
        LOG("⚛ 量子类+枚举+程序组合测试")
        LOG("状态: 叠加→纠缠→坍缩")
        
        // Bell态: 叠加→纠缠→测量
        量子门 H 0
        量子门 CNOT 0 1
        LOG("✅ 叠加+纠缠创建完成")
        
        测量 0
        测量 1
        LOG("✅ 测量完成(坍缩)")
        
        LOG("⚛ 量子类+枚举+程序测试完成!")
    }
}
