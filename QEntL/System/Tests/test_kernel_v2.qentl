// QEntL内核V2.0测试程序
// 测试: 函数参数+返回值+IF/ELSE+WHILE+量子操作+字符串拼接
配置 {
    测试模式: true,
    版本: "2.0.0"
}

// 测试1: 加法函数
测试加法: 函数() {
    让 结果 = 加法(3, 5)
    如果 结果 == 8 {
        LOG("✅ 加法测试通过: 3+5=8")
    } 否则 {
        LOG("❌ 加法测试失败")
    }
}

// 测试2: 最大值函数(嵌套IF)
测试最大值: 函数() {
    让 a = 最大值(7, 3)
    让 b = 最大值(2, 9)
    如果 a == 7 {
        LOG("✅ 最大值测试1通过: max(7,3)=7")
    } 否则 {
        LOG("❌ 最大值测试1失败")
    }
    如果 b == 9 {
        LOG("✅ 最大值测试2通过: max(2,9)=9")
    } 否则 {
        LOG("❌ 最大值测试2失败")
    }
}

// 测试3: WHILE循环(退相干检查)
测试退相干: 函数() {
    让 检查次数 = 0
    当 检查次数 < 3 {
        让 检查次数 = 检查次数 + 1
    }
    如果 检查次数 == 3 {
        LOG("✅ WHILE测试通过: 循环3次")
    } 否则 {
        LOG("❌ WHILE测试失败")
    }
}

// 测试4: 量子Bell态
测试Bell: 函数() {
    创建Bell态()
    LOG("✅ Bell态测试完成")
}

// 测试5: 全叠加(并行)
测试叠加: 函数() {
    全叠加()
    LOG("✅ 叠加态测试完成")
}

// 测试6: 字符串拼接
测试拼接: 函数() {
    让 名字 = "中华"
    让 问候 = "你好，" + 名字 + "！"
    LOG(问候)
    LOG("✅ 字符串拼接测试完成")
}

quantum_program 内核测试 {
    setup: 函数() {
        LOG("⚛ QEntL内核V2.0测试开始")
        测试加法()
        测试最大值()
        测试退相干()
        测试Bell()
        测试叠加()
        测试拼接()
        LOG("⚛ QEntL内核V2.0测试完成!")
    }
}
