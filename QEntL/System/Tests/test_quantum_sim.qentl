// QEntL量子电路模拟器 - 综合测试
// 测试: quantum_enum + 循环 + 递归 + 数组 + 比较 + 打印

// 量子门枚举
quantum_enum 量子门类型 {
    H门,
    X门,
    Y门,
    Z门,
    CNOT门
}

// 计算概率幅
概率平方: 函数(幅值) {
    返回 幅值 * 幅值
}

// 计算总概率
总概率: 函数(状态) {
    让 总 = 0
    循环 幅 在 状态 {
        让 总 = 总 + 概率平方(幅)
    }
    返回 总
}

// 寻找最大概率态
最大概率态: 函数(状态) {
    让 最大概率 = 0
    让 最大索引 = 0
    循环 i 在 范围(0, 长度(状态)) {
        让 概率 = 概率平方(状态[i])
        如果 概率 > 最大概率 {
            让 最大概率 = 概率
            让 最大索引 = i
        }
    }
    返回 最大索引
}

// 主测试
主函数: 函数() {
    // 模拟2量子比特|00>态
    让 状态 = [1.0, 0.0, 0.0, 0.0]
    
    // 应用H门到第0量子比特 → 均匀叠加
    让 新状态 = [0.707, 0.707, 0.0, 0.0]
    
    // 计算概率
    打印("总概率:")
    打印(总概率(新状态))
    
    // 找最大概率态
    打印("最大概率态索引:")
    打印(最大概率态(新状态))
    
    // 测试枚举
    打印("H门类型:")
    打印(量子门类型.H门)
    
    // 递归测试: 计算n量子比特的状态数
    让 n = 3
    打印("3量子比特状态数:")
    打印(阶乘_2(n))
}

// 辅助: 2^n
阶乘_2: 函数(n) {
    如果 n <= 0 {
        返回 1
    }
    返回 2 * 阶乘_2(n - 1)
}
