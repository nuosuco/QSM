print("=" * 60)
print("  QEntL Full-Stack Yi Character Recognition Training")
print("  Quantum Neural Superposition (QNS) Model")
print("  滇川黔桂彝文训练系统")
print("=" * 60)
print("")

// Execute training pipeline
let results = train_qns_model("/root/QSM/data", "/root/QSM/models/yi_qns")

print("")
