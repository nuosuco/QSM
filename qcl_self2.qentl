    while (si < stmt_count):
        base = stmt_start[si]
        next_base = tcount
        idx_next = si + 1
        limit = stmt_count - 1
        if (si < limit):
            next_base = stmt_start[idx_next]
        end
        stmt_len = next_base - base
        stype = stmt_type[si]

        idx_name = base + 1
        idx_fmt = base + 2

        if (stype == 0):
            name_s = tstart[idx_name]
            name_e = tend[idx_name]
            name_l = name_e - name_s

            var vi = 0
            while (vi < name_l):
                var cpos = name_s + vi
                var ch3 = str_char_at(src, cpos)
                sp[spos] = ch3
                spos = spos + 1
                vi = vi + 1
            end
            var_name_off = name_offset
            name_offset = name_offset + name_l

            var_is_call = 0
            if (stmt_len >= 5):
                var_fc_idx = base + 4
                var_fc_at = ttype[var_fc_idx]
                if (var_fc_at == 13):
                    var_is_call = 1
                end
            end
            if (var_is_call == 1):
                var_fc_idx = base + 3
                var_fc_s = tstart[var_fc_idx]
                var_fc_e = tend[var_fc_idx]
                var_fc_l = var_fc_e - var_fc_s
                var_fc_off = name_offset
                var_fc_vi = 0
                while (var_fc_vi < var_fc_l):
                    var_fc_cpos = var_fc_s + var_fc_vi
                    var_fc_ch = str_char_at(src, var_fc_cpos)
                    sp[spos] = var_fc_ch
                    spos = spos + 1
                    var_fc_vi = var_fc_vi + 1
                end
                name_offset = name_offset + var_fc_l
                var_fc_nargs = 0
                var_fc_scan = base + 5
                var_fc_scan_end = base + 5
                while (var_fc_scan < tcount):
                    var_fc_at = ttype[var_fc_scan]
                    if (var_fc_at == 14):
                        var_fc_scan_end = var_fc_scan
                        var_fc_scan = tcount
                    end
                    var_fc_scan = var_fc_scan + 1
                end
                var_fc_scan = base + 5
                while (var_fc_scan < var_fc_scan_end):
                    var_fc_at = ttype[var_fc_scan]
                    if (var_fc_at == 2):
                        var_fc_as = tstart[var_fc_scan]
                        var_fc_ae = tend[var_fc_scan]
                        var_fc_al = var_fc_ae - var_fc_as
                        var_fc_astr = str_sub(src, var_fc_as, var_fc_al)
                        var_fc_av = str_to_int(var_fc_astr)
                        bc[bpos] = 120
                        bpos = bpos + 1
                        bc[bpos] = var_fc_av
                        bpos = bpos + 1
                        bc[bpos] = 0
                        bpos = bpos + 1
                        var_fc_nargs = var_fc_nargs + 1
                    end
                    if (var_fc_at == 1):
                        var_fc_as = tstart[var_fc_scan]
                        var_fc_ae = tend[var_fc_scan]
                        var_fc_al = var_fc_ae - var_fc_as
                        var_fc_off = name_offset
                        var_fc_vi = 0
                        while (var_fc_vi < var_fc_al):
                            var_fc_cpos = var_fc_as + var_fc_vi
                            var_fc_ch = str_char_at(src, var_fc_cpos)
                            sp[spos] = var_fc_ch
                            spos = spos + 1
                            var_fc_vi = var_fc_vi + 1
                        end
                        name_offset = name_offset + var_fc_al
                        bc[bpos] = 125
                        bpos = bpos + 1
                        bc[bpos] = var_fc_off
                        bpos = bpos + 1
                        bc[bpos] = 0
                        bpos = bpos + 1
                        bc[bpos] = var_fc_al
                        bpos = bpos + 1
                        bc[bpos] = 0
                        bpos = bpos + 1
