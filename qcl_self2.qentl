def is_digit(c):
    if (c >= 48):
        if (c <= 57):
            return 1
        end
    end
    return 0
end

def is_alpha(c):
    if (c >= 65):
        if (c <= 90):
            return 1
        end
    end
    if (c >= 97):
        if (c <= 122):
            return 1
        end
    end
    if (c == 95):
        return 1
    end
    return 0
end

def is_space(c):
    if (c == 32):
        return 1
    end
    if (c == 9):
        return 1
    end
    if (c == 13):
        return 1
    end
    if (c == 10):
        return 1
    end
    return 0
end

def 编译():
    var r = 0
    var src = file_read("/tmp/hello_src.txt")
    var slen = len(src)
    printf("读取 %d 字节\n", slen)
    if (slen == 0):
        printf("错误: 文件为空\n")
        return 0
    end

    var pos = 0
    var ttype[60]
    var tstart[60]
    var tend[60]
    var tcount = 0
    var mode = 0

    while (pos < slen):
        var c = str_char_at(src, pos)
        var skip = 0
        if (mode == 0):
            if (is_space(c) == 1):
                pos = pos + 1
            end
            if (is_alpha(c) == 1):
                ttype[tcount] = 1
                tstart[tcount] = pos
                tcount = tcount + 1
                mode = 1
            end
            if (is_digit(c) == 1):
                ttype[tcount] = 2
                tstart[tcount] = pos
                tcount = tcount + 1
                mode = 2
            end
            if (c == 61):
                var npos3 = pos + 1
                var nc3 = str_char_at(src, npos3)
                if (nc3 == 61):
                    ttype[tcount] = 16
                    tstart[tcount] = pos
                    tend[tcount] = pos + 2
                    tcount = tcount + 1
                    pos = pos + 2
                end
                if (nc3 != 61):
                    ttype[tcount] = 7
                    tstart[tcount] = pos
                    tend[tcount] = pos + 1
                    tcount = tcount + 1
                    pos = pos + 1
                end
            end
            if (c == 43):
                ttype[tcount] = 8
                tstart[tcount] = pos
                tend[tcount] = pos + 1
                tcount = tcount + 1
                pos = pos + 1
            end
            if (c == 45):
                ttype[tcount] = 9
                tstart[tcount] = pos
                tend[tcount] = pos + 1
                tcount = tcount + 1
                pos = pos + 1
            end
            if (c == 42):
                ttype[tcount] = 10
                tstart[tcount] = pos
                tend[tcount] = pos + 1
                tcount = tcount + 1
                pos = pos + 1
            end
            if (c == 47):
                ttype[tcount] = 11
                tstart[tcount] = pos
                tend[tcount] = pos + 1
                tcount = tcount + 1
                pos = pos + 1
            end
            if (c == 34):
                ttype[tcount] = 12
                tstart[tcount] = pos + 1
                tcount = tcount + 1
                mode = 3
                pos = pos + 1
                skip = 1
            end
            if (c == 40):
                ttype[tcount] = 13
                tstart[tcount] = pos
                tend[tcount] = pos + 1
                tcount = tcount + 1
                pos = pos + 1
            end
            if (c == 41):
                ttype[tcount] = 14
                tstart[tcount] = pos
                tend[tcount] = pos + 1
                tcount = tcount + 1
                pos = pos + 1
            end
            if (c == 44):
                ttype[tcount] = 15
                tstart[tcount] = pos
                tend[tcount] = pos + 1
                tcount = tcount + 1
                pos = pos + 1
            end
            if (c == 60):
                ttype[tcount] = 18
                tstart[tcount] = pos
                tend[tcount] = pos + 1
                tcount = tcount + 1
                pos = pos + 1
            end
            if (c == 62):
                ttype[tcount] = 19
                tstart[tcount] = pos
                tend[tcount] = pos + 1
                tcount = tcount + 1
                pos = pos + 1
            end
            if (c == 33):
                var npos2 = pos + 1
                var nc2 = str_char_at(src, npos2)
                if (nc2 == 61):
                    ttype[tcount] = 17
                    tstart[tcount] = pos
                    tend[tcount] = pos + 2
                    tcount = tcount + 1
                    pos = pos + 2
                end
            end
            if (c == 58):
                ttype[tcount] = 20
                tstart[tcount] = pos
                tend[tcount] = pos + 1
                tcount = tcount + 1
                pos = pos + 1
            end
        end
        if (mode == 1):
            if (is_alpha(c) == 1):
                pos = pos + 1
            end
            if (is_digit(c) == 1):
                pos = pos + 1
            end
            if (is_alpha(c) == 0):
                if (is_digit(c) == 0):
                    var idx = tcount
                    idx = idx - 1
                    tend[idx] = pos
                    mode = 0
                end
            end
        end
        if (mode == 2):
            if (is_digit(c) == 1):
                pos = pos + 1
            end
            if (is_digit(c) == 0):
                var idx2 = tcount
                idx2 = idx2 - 1
                tend[idx2] = pos
                mode = 0
            end
        end
        if (mode == 3):
            if (skip == 0):
                if (c == 34):
                    var idx5 = tcount
                    idx5 = idx5 - 1
                    tend[idx5] = pos
                    mode = 0
                end
                pos = pos + 1
            end
        end
    end
    if (mode == 1):
        var idx3 = tcount
        idx3 = idx3 - 1
        tend[idx3] = slen
    end
    if (mode == 2):
        var idx4 = tcount
        idx4 = idx4 - 1
        tend[idx4] = slen
    end

    printf("tokens=%d\n", tcount)

    var stmt_start[10]
    var stmt_type[10]
    var stmt_count = 0
    var ti = 0
    var kw_s = 0
    var kw_e = 0
    var kw_l = 0
    var kw = str_sub(src, 0, 1)
    var is_var = 0
    var is_printf = 0
    var is_if = 0
    var is_else = 0
    var is_while = 0
    var is_end = 0
    var is_def = 0
    var is_assign = 0
    var is_call = 0
    var next_ti = 0
    var end_c0 = 0
    var ret_c0 = 0
    var return_active = 0
    while (ti < tcount):
        if (ttype[ti] == 1):
            kw_s = tstart[ti]
            kw_e = tend[ti]
            kw_l = kw_e - kw_s
            kw = str_sub(src, kw_s, kw_l)
            is_def = str_eq(kw, "def")
            is_var = str_eq(kw, "var")
            is_printf = str_eq(kw, "printf")
            is_if = str_eq(kw, "if")
            is_else = str_eq(kw, "else")
            is_while = str_eq(kw, "while")
            is_end = 0
            if (kw_l == 3):
                end_c0 = str_char_at(kw, 0)
                if (end_c0 == 101):
                    is_end = 1
                end
            end
            is_return = 0
            if (kw_l == 6):
                ret_c0 = str_char_at(kw, 0)
                if (ret_c0 == 114):
                    is_return = 1
                end
            end
            is_assign = 0
            is_call = 0
            next_ti = ti + 1
            if (next_ti < tcount):
                if (ttype[next_ti] == 7):
                    is_assign = 1
                end
                if (ttype[next_ti] == 13):
                    prev_ti = ti - 1
                    if (prev_ti >= 0):
                        if (ttype[prev_ti] == 7):
                            is_call = 0
                        else:
                            is_call = 1
                        end
                    else:
                        is_call = 1
                    end
                end
            end
            if (skip_next_assign == 1):
                is_assign = 0
                skip_next_assign = 0
            end
            if (skip_next_call == 1):
                is_call = 0
                skip_next_call = 0
            end
            if (return_active == 1):
                if (is_end == 0):
                    is_var = 0
                    is_printf = 0
                    is_if = 0
                    is_else = 0
                    is_while = 0
                    is_call = 0
                    is_assign = 0
                    is_def = 0
                    is_return = 0
                end
            end
            if (is_var == 1):
                stmt_start[stmt_count] = ti
                stmt_type[stmt_count] = 0
                stmt_count = stmt_count + 1
                skip_next_assign = 1
                skip_next_call = 1
            end
            if (is_printf == 1):
                stmt_start[stmt_count] = ti
                stmt_type[stmt_count] = 1
                stmt_count = stmt_count + 1
            end
            if (is_if == 1):
                stmt_start[stmt_count] = ti
                stmt_type[stmt_count] = 2
                stmt_count = stmt_count + 1
            end
            if (is_else == 1):
                stmt_start[stmt_count] = ti
                stmt_type[stmt_count] = 4
                stmt_count = stmt_count + 1
            end
            if (is_while == 1):
                stmt_start[stmt_count] = ti
                stmt_type[stmt_count] = 5
                stmt_count = stmt_count + 1
            end
            if (is_end == 1):
                stmt_start[stmt_count] = ti
                stmt_type[stmt_count] = 3
                stmt_count = stmt_count + 1
            end
            if (is_return == 1):
                stmt_start[stmt_count] = ti
                stmt_type[stmt_count] = 9
                stmt_count = stmt_count + 1
                return_active = 1
            end
            if (is_end == 1):
                return_active = 0
            end
            if (is_def == 1):
                stmt_start[stmt_count] = ti
                stmt_type[stmt_count] = 7
                stmt_count = stmt_count + 1
                skip_next_call = 1
            end
            if (is_call == 1):
                if (is_def == 0):
                    if (is_var == 0):
                        if (is_printf == 0):
                            if (is_if == 0):
                                if (is_else == 0):
                                    if (is_while == 0):
                                        if (is_end == 0):
                                            stmt_start[stmt_count] = ti
                                            stmt_type[stmt_count] = 8
                                            stmt_count = stmt_count + 1
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
            if (is_assign == 1):
                if (is_var == 0):
                    if (is_printf == 0):
                        if (is_if == 0):
                            if (is_else == 0):
                                if (is_while == 0):
                                    if (is_end == 0):
                                        stmt_start[stmt_count] = ti
                                        stmt_type[stmt_count] = 6
                                        stmt_count = stmt_count + 1
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
        ti = ti + 1
    end
    printf("语句数=%d\n", stmt_count)
    if (stmt_count == 0):
        printf("错误: 没有语句\n")
        return 0
    end
    r = r + 1

    var bc[500]
    var bpos = 0
    var sp[200]
    var spos = 0

    bc[bpos] = 20
    bpos = bpos + 1
    bc[bpos] = 0
    bpos = bpos + 1
    bc[bpos] = 0
    bpos = bpos + 1
    bc[bpos] = 0
    bpos = bpos + 1

    var code_start = bpos
