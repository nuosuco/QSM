    bc[bpos] = 4
    bpos = bpos + 1
    bc[bpos] = 0
    bpos = bpos + 1
    bc[bpos] = 0
    bpos = bpos + 1

    bc[bpos] = 255
    bpos = bpos + 1

    var fn = "main"
    var fi = 0
    while (fi < 4):
        var ch = str_char_at(fn, fi)
        sp[spos] = ch
        spos = spos + 1
        fi = fi + 1
    end

    var pn = "printf"
    var pi = 0
    while (pi < 6):
        var ch2 = str_char_at(pn, pi)
        sp[spos] = ch2
        spos = spos + 1
        pi = pi + 1
    end

    var name_offset = 10

    var si = 0
    var base = 0
