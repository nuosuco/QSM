# OpenClaw internal
.openclaw/
.clawhub/

# Python cache
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Temporary files
*.log
*.tmp
*.pid

# Large model files (use Git LFS or separate storage)
Models/QSM/bin/*.pth
Models/QSM/bin/*.safetensors

# OS files
.DS_Store
Thumbs.db

# Node modules
node_modules/

# Backup files
*~
*.bak
# Large model files (>100MB, exceed GitHub limit)
Models/QSM/bin/archive/Q1_v2_pretrained.pth
Models/QSM/bin/archive/*.pth
Models/QSM/bin/*.pth

# === 量子自举原则：禁止第三方文件格式 ===
# ❌ 禁止 .py 文件（QEntL项目不依赖Python）
*.py
!Models/QSM/train_v14_alibi.py
!Models/QSM/upgrade_lora_r32.py
!QSM/api/qsm_v14_api.py
!QEntL/System/Compiler/qentl_compiler_v3.py
!QEntL/System/Runtime/qbc_vm.py
!QEntL/System/Runtime/qentl_api.py
!QEntL/System/Tests/test_qentl.py
# ❌ 禁止 .pth 模型文件（用 .qim/.json 替代）
*.pth
# ❌ 禁止 .pyc 缓存
*.pyc
*.pyo
# ❌ 禁止 .js 文件（用 .qentl 替代）
# *.js  # 暂时保留web的js，未来也要消灭
# __pycache__
__pycache__/
