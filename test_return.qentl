def 测试函数():
    var 列表 = [];
    列表.append("a");
    列表.append("b");
    列表.append("c");
    print("函数内 len=", len(列表));
    return 列表;

def 主程序():
    var 结果 = 测试函数();
    print("函数外 len=", len(结果));
    var i = 0;
    while i < len(结果):
        print("  元素:", 结果[i]);
        i = i + 1;
    return 0;

主程序();