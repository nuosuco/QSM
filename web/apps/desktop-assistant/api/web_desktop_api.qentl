 * @brief API入口函数
 */
function main(): void {
    Console.info("========================================");
    Console.info("  Web桌面量子助手API");
    Console.info("  QEntL全栈方案 | 运行在QVM上");
    Console.info("========================================");
    
    let api = new WebDesktopQuantumAssistantAPI();
    
    Console.info("[API] 端点列表:");
    Console.info("  GET  /api/web-desktop/status");
    Console.info("  POST /api/web-desktop/chat");
    Console.info("  GET  /api/web-desktop/quantum/state");
    Console.info("  POST /api/web-desktop/quantum/measure");
    Console.info("  POST /api/web-desktop/quantum/entangle");
    Console.info("  GET  /api/web-desktop/models");
    Console.info("  GET  /api/web-desktop/version");
    Console.info("  GET  /api/web-desktop/sessions");
    
    Console.info("[API] 三大圣律:");
    Console.info("  1. 为每个人服务，服务人类！");
    Console.info("  2. 保护好每个人的生命安全、健康快乐、幸福生活！");
    Console.info("  3. 没有以上两个前提，其他就不能发生！");
    
    Console.info("[API] 就绪 ✓");
}

main();
