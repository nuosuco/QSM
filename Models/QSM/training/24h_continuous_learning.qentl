import quantum.gui as qgui; 
import quantum.interaction as qinter; 
 
// GUI功能结构 
struct GuiFunctionInjection { 
    qgui.Window main_window; 
    qgui.ControlPanel control_panel; 
    qgui.MonitoringPanel monitoring_panel; 
    bool gui_active; 
} 
 
// 自动初始化GUI功能 
function auto_initialize_gui(program_name) { 
    // 创建主窗口 
    gui_injection.main_window = qgui.create_window(program_name); 
    gui_injection.gui_active = true; 
    return gui_injection; 
} 
 
// 编程调用GUI 
function call_gui(action, data) { 
    return qinter.call_gui_function(action, data); 
} 
 
