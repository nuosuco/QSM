# Aurora Engine - WeCom推送模块 QEntL版本
# 通过HTTP接口发送消息到企业微信

# 量子基因编码
QG-DOC-IMPL-WECOM-PUSHER-G7H8I9J0

// ============================================================
// WeCom推送器 - QEntL版本
// ============================================================

quantum_class WeComPusher {
  // 核心属性
  public gateway_url: String = "http://localhost:14121"
  private retry_delay: Integer = 3
  private max_retries: Integer = 3
  
  // ============================================================
  // 初始化
  // ============================================================
  
  public function init(url: String) {
    if url != "" {
      gateway_url = url.trim_end('/')
    }
  }
  
  // ============================================================
  // 发送文本消息
  // ============================================================
  
  public function send_text(content: String, title: String = "Aurora Engine"): Boolean {
    var payload = {
      title: title,
      content: content,
      channel: "wecom"
    }
    
    return post_to_gateway(gateway_url + "/api/broadcast", payload)
  }
  
  // ============================================================
  // 发送结构化报告
  // ============================================================
  
  public function send_report(report_type: String, items: Array<Object>): Boolean {
    var now = format_timestamp(current_timestamp())
    var lines = []
    
    lines.append("📊 **" + now + "**")
    lines.append("")
    lines.append("**" + report_type + "**")
    lines.append("")
    
    for item in items {
      var icon = item.icon || "•"
      var task = item.task || ""
      var status = item.status || "unknown"
      var detail = item.detail || ""
      
      lines.append(icon + " **" + task + "** [" + status + "]")
      if detail != "" {
        lines.append("  " + detail)
      }
    }
    
    var text = "\n".join(lines)
    return send_text(text, "Aurora " + report_type)
  }
  
  // ============================================================
  // 发送告警
  // ============================================================
  
  public function send_alert(alert_type: String, message: String, severity: String = "warning"): Boolean {
    var emoji = severity == "critical" ? "🚨" : "⚠️"
    var lines = [
      emoji + " **Aurora Alert**",
      "",
      "**Type**: " + alert_type,
      "**Time**: " + format_timestamp(current_timestamp()),
      "",
      message
    ]
    
    var text = "\n".join(lines)
    return send_text(text, "AURORA ALERT")
  }
  
  // ============================================================
  // 发送任务结果
  // ============================================================
  
  public function send_task_result(task_name: String, success: Boolean, details: String): Boolean {
    var status_icon = success ? "✅" : "❌"
    var lines = [
      status_icon + " **任务完成**: " + task_name,
      "",
      "```",
      details.slice(0, 2000),
      "```"
    ]
    
    var text = "\n".join(lines)
    return send_text(text, "Aurora: " + task_name)
  }
}

// ============================================================
// 入口点
// ============================================================

function main(): Integer {
  var pusher = new WeComPusher()
  pusher.init("")
  
  print("WeCom推送器初始化完成")
  print("Gateway: " + pusher.gateway_url)
  
  return 0
}

